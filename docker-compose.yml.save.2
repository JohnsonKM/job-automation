

services:
  postgres:
    image: postgres:15
    env_file: .env
    ports:
      - "5432:5432"
    volumes:
      - ./db/init.sql:/docker-entrypoint-initdb.d/init.sql

  redis:
    image: redis:7

  scraper:
    build: ./services/scraper
    env_file: .env
    depends_on:
      - postgres
      - redis

  worker:
    build: s_on:
      - postgres
      - redis

  dashboard:
    build: ./services/dashboard
    ports:
      - "8000:8000"
    env_file: .env
    depends_on:
      - postgres

 
